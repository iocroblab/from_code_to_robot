{
  "exercise": {
    "id": "1-1",
    "description": "Check myRobot home configuration and end-effector pose",
    "setup": "robot = evalin('base','myRobot');",
    "variables": [
      {
        "name": "robot",
        "type": "rigidBodyTree"
      }
    ],
    "tests": [
      {
        "description": "Robot is in home configuration [0,0]",
        "code": "q = [homeConfiguration(robot).JointPosition];",
        "expected": [0, 0]
      },
      {
        "description": "End-effector pose at home configuration",
        "code": "T = getTransform(robot, homeConfiguration(robot), robot.BodyNames{end});",
        "expected": [
          [0.0000, -1.0000, 0.0000, -0.6500],
          [0.0000,  0.0000, 1.0000,  0.0000],
          [-1.0000, 0.0000, 0.0000,  0.0000],
          [0.0000,  0.0000, 0.0000,  1.0000]
        ],
        "tolerance": 1e-6
      }
    ]
  }
}
