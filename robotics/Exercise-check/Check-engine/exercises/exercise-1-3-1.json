{
    "exercise": {
        "id": "1-3-1",
        "description": "Checking Symbolic Variable Setup and Joint Limits",
        "variables": [
            {
                "name": "q1",
                "type": "sym"
            },
            {
                "name": "q2",
                "type": "sym"
            },
            {
                "name": "q3",
                "type": "sym"
            },
            {
                "description": "Checking if variables are real",
                "name": "isreal(q1)&&isreal(q2)&&isreal(q3)",
                "expected": true, 
                "output_ok": "variables are setup correctly", 
                "output_fail": "one or more variables are not assumed as real"

            },
            {
                "name": "q",
                "type": "sym"
            },
            {
                "description": "Checking dimension of q",
                "name": "size(q,2)",
                "expected": 3,
                "output_ok": "correct dimensions of q", 
                "output_fail": "incorrect dimension of q"
            },
            {
                "name": "limit_1",
                "type": "double",
                "expected": [0.1, 0.4]
            },
            {
                "name": "limit_2",
                "type": "double",
                "expected": [-6.2832, 6.2832],
                "hidden": true
            },
            {
                "name": "limit_3",
                "type": "double",
                "expected": [-6.2832, 6.2832],
                "hidden": true
            }
        ]
    }
}
