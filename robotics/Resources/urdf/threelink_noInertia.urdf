<!--
  Simplified 3-DOF manipulator for teaching inertia calculation.
  - Compact model (no ground plane or end-effector link).
  - Base and moving links have inertial blocks for Gazebo.
  Box (length along X, width along Y, height along Z) inertia about its center:
    Ixx = (m/12) * (width^2 + height^2)
    Iyy = (m/12) * (length^2 + height^2)
    Izz = (m/12) * (length^2 + width^2)
-->
<robot name="threelink_easy">
  <!-- World link (root for Gazebo) -->
  <link name="world"/>
  <!-- Link 1: Shoulder pan link -->
  <link name="shoulder_pan_link">
    <visual>
      <origin rpy="0 0 0" xyz="0.15 0 0.2"/>
      <geometry>
        <box size="0.3 0.1 0.1"/>
      </geometry>
      <material name="link1_color">
        <color rgba="0.2 0.1 0.8 1.0"/>
      </material>
    </visual>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.15"/>
      <geometry>
        <cylinder length="0.3" radius="0.15"/>
      </geometry>
      <material name="joint_color">
        <color rgba="0.3 0.3 0.9 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.15 0 0.2"/>
      <geometry>
        <box size="0.3 0.1 0.1"/>
      </geometry>
    </collision>
  </link>
  <!-- Link 2: Shoulder lift link -->
  <link name="shoulder_lift_link">
    <visual>
      <origin rpy="0 0 0" xyz="0.25 0 0"/>
      <geometry>
        <box size="0.5 0.1 0.1"/>
      </geometry>
      <material name="link2_color">
        <color rgba="0.2 0.8 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.25 0 0"/>
      <geometry>
        <box size="0.5 0.1 0.1"/>
      </geometry>
    </collision>
  </link>
  <!-- Link 3: Elbow link -->
  <link name="elbow_link">
    <visual>
      <origin rpy="0 0 0" xyz="0.25 0 0"/>
      <geometry>
        <box size="0.5 0.1 0.1"/>
      </geometry>
      <material name="link3_color">
        <color rgba="0.8 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.25 0 0"/>
      <geometry>
        <box size="0.5 0.1 0.1"/>
      </geometry>
    </collision>
  </link>
  <!-- Tool frame at the end of the elbow link -->
  <link name="tool0"/>
  <!-- Joints (all revolute about Z) -->
  <joint name="shoulder_pan_joint" type="revolute">
    <parent link="world"/>
    <child link="shoulder_pan_link"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="150.0" lower="-1000.0" upper="1000.0" velocity="2.0"/>
  </joint>
  <joint name="shoulder_lift_joint" type="revolute">
    <parent link="shoulder_pan_link"/>
    <child link="shoulder_lift_link"/>
    <origin rpy="1.570796326795 0 0" xyz="0.3 0 0.2"/>
    <axis xyz="0 0 1"/>
    <limit effort="150.0" lower="-1000.0" upper="1000.0" velocity="2.0"/>
  </joint>
  <joint name="elbow_joint" type="revolute">
    <parent link="shoulder_lift_link"/>
    <child link="elbow_link"/>
    <origin rpy="0.0 0 0" xyz="0.5 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="150.0" lower="-1000.0" upper="1000.0" velocity="2.0"/>
  </joint>
  <joint name="tool0_joint" type="fixed">
    <parent link="elbow_link"/>
    <child link="tool0"/>
    <origin rpy="0 0 0" xyz="0.5 0 0"/>
  </joint>
  <!-- ros2_control block kept minimal for compatibility -->
  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="shoulder_pan_joint">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="shoulder_lift_joint">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="elbow_joint">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>
  <!-- Gazebo + gz_ros2_control plugin -->
  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>/home/constanin/git_ws/install/threelink_manipulator/share/threelink_manipulator/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>
</robot>
